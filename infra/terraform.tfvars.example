# AWS Configuration
# Singapore region for low latency to Asian exchanges
aws_region  = "ap-southeast-1"
environment = "production"

# EC2 Configuration
instance_type    = "t3.medium"
ebs_volume_size  = 50

# SSH Access
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC... your-public-key-here"
allowed_ssh_cidrs = [
  "1.2.3.4/32",
]

# Grafana Access
allowed_grafana_cidrs = [
  "1.2.3.4/32",
]

# Alerts
alert_email = "your-email@example.com"

# Project Settings
project_name = "dislocation-trader"
vpc_cidr     = "10.0.0.0/16"
subnet_cidr  = "10.0.1.0/24"
