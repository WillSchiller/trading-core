{
  "id": null,
  "uid": "trading-summary",
  "title": "Paper Trading Summary",
  "tags": ["dislocation-trader"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Opportunities Found",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*) as \"Opportunities\" FROM opportunities",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "blue"}]}
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Skipped (Unprofitable)",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*) as \"Skipped\" FROM opportunities WHERE status = 'skipped'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "orange"}]}
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Executed (Paper)",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*) as \"Executed\" FROM executions WHERE status = 'confirmed'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}]}
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Simulated P&L",
      "description": "Total profit/loss from paper trades",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COALESCE(ROUND(SUM(realized_pnl_usd)::numeric, 2), 0) as \"P&L\" FROM executions WHERE status = 'confirmed'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": null, "color": "red"},
            {"value": 0, "color": "green"}
          ]}
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg Estimated Profit",
      "description": "Average estimated profit BEFORE execution",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COALESCE(ROUND(AVG(estimated_profit_usd)::numeric, 4), 0) as \"Est Profit\" FROM opportunities WHERE estimated_profit_usd IS NOT NULL",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": null, "color": "red"},
            {"value": 0, "color": "green"}
          ]}
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Recent Activity",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT o.detected_at as \"Time\", ROUND(o.spread_bps::numeric, 2) as \"Spread (bps)\", o.status as \"Status\", ROUND(o.estimated_profit_usd::numeric, 4) as \"Est Profit\", COALESCE(ROUND(e.realized_pnl_usd::numeric, 4), NULL) as \"Simulated P&L\", o.skip_reason as \"Skip Reason\" FROM opportunities o LEFT JOIN executions e ON e.opportunity_id = o.id ORDER BY o.detected_at DESC LIMIT 20",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Status"}, "properties": [{"id": "custom.width", "value": 80}]},
          {"matcher": {"id": "byName", "options": "Skip Reason"}, "properties": [{"id": "custom.width", "value": 300}]}
        ]
      }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Outcome Breakdown",
      "gridPos": {"x": 0, "y": 12, "w": 8, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT status as \"Status\", COUNT(*) as \"Count\" FROM opportunities GROUP BY status",
        "format": "table"
      }],
      "options": {"legend": {"displayMode": "list", "placement": "right"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cumulative P&L Over Time",
      "gridPos": {"x": 8, "y": 12, "w": 16, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT created_at as time, SUM(realized_pnl_usd) OVER (ORDER BY created_at) as \"Cumulative P&L\" FROM executions WHERE status = 'confirmed' ORDER BY created_at",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "palette-classic"}
        }
      }
    }
  ]
}
