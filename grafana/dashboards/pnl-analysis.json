          "rawSql": "WITH total_opps AS (SELECT COUNT(*) as cnt FROM opportunities WHERE detected_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$pair' = '0' OR pair_id = $pair) AND ('$chain' = 'all' OR chain::text = '$chain') AND status = 'submitted'), filled_execs AS (SELECT COUNT(*) as cnt FROM executions WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$pair' = '0' OR pair_id = $pair) AND ('$chain' = 'all' OR chain::text = '$chain') AND ('$paper_mode' = 'all' OR is_paper_trade::text = '$paper_mode') AND ('$strategy' = 'all' OR strategy = '$strategy') AND status IN ('confirmed', 'filled')) SELECT CASE WHEN total_opps.cnt > 0 THEN ROUND(100.0 * filled_execs.cnt / total_opps.cnt, 1) ELSE 0 END as value FROM total_opps, filled_execs",
