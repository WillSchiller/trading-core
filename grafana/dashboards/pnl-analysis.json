      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COUNT(*) as value FROM executions WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$pair' = '0' OR pair_id = $pair) AND ('$chain' = 'all' OR chain::text = '$chain') AND ('$paper_mode' = 'all' OR is_paper_trade::text = '$paper_mode') AND ('$strategy' = 'all' OR strategy = '$strategy')",
