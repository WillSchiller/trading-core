{
  "id": null,
  "uid": "pnl-analysis",
  "title": "P&L Analysis",
  "tags": ["dislocation-trader", "pnl", "performance"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "pair",
        "type": "query",
        "label": "Pair",
        "datasource": {
          "type": "postgres",
          "uid": "postgresql"
        },
        "definition": "SELECT id as __value, canonical as __text FROM pairs WHERE is_enabled = true ORDER BY canonical",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": "0",
        "current": {},
        "options": []
      },
      {
        "name": "chain",
        "type": "custom",
        "label": "Chain",
        "options": [
          {"text": "All", "value": "all", "selected": true},
          {"text": "base", "value": "base", "selected": false},
          {"text": "mainnet", "value": "mainnet", "selected": false}
        ],
        "current": {"text": "All", "value": "all"},
        "multi": false,
        "includeAll": false
      },
      {
        "name": "paper_mode",
        "type": "custom",
        "label": "Trade Type",
        "options": [
          {"text": "All", "value": "all", "selected": true},
          {"text": "Paper", "value": "true", "selected": false},
          {"text": "Live", "value": "false", "selected": false}
        ],
        "current": {"text": "All", "value": "all"},
        "multi": false,
        "includeAll": false
      },
      {
        "name": "strategy",
        "type": "custom",
        "label": "Strategy",
        "options": [
          {"text": "All", "value": "all", "selected": true},
          {"text": "Dislocation", "value": "dislocation", "selected": false},
          {"text": "Rank Space", "value": "rank_space", "selected": false}
        ],
        "current": {"text": "All", "value": "all"},
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Realized P&L",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COALESCE(SUM(realized_pnl_usd), 0) as value FROM executions WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$pair' = '0' OR pair_id = $pair) AND ('$chain' = 'all' OR chain::text = '$chain') AND ('$paper_mode' = 'all' OR is_paper_trade::text = '$paper_mode') AND ('$strategy' = 'all' OR strategy = '$strategy') AND realized_pnl_usd IS NOT NULL",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": -1000, "color": "red"},
              {"value": 0, "color": "yellow"},
              {"value": 100, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Win Rate",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT CASE WHEN COUNT(*) > 0 THEN ROUND(100.0 * SUM(CASE WHEN realized_pnl_usd > 0 THEN 1 ELSE 0 END) / COUNT(*), 1) ELSE 0 END as value FROM executions WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$pair' = '0' OR pair_id = $pair) AND ('$chain' = 'all' OR chain::text = '$chain') AND ('$paper_mode' = 'all' OR is_paper_trade::text = '$paper_mode') AND ('$strategy' = 'all' OR strategy = '$strategy') AND realized_pnl_usd IS NOT NULL",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 50, "color": "yellow"},
              {"value": 60, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Trade Size",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT AVG(input_amount_human * quoted_price) as value FROM executions WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$pair' = '0' OR pair_id = $pair) AND ('$chain' = 'all' OR chain::text = '$chain') AND ('$paper_mode' = 'all' OR is_paper_trade::text = '$paper_mode') AND ('$strategy' = 'all' OR strategy = '$strategy') AND input_amount_human IS NOT NULL AND quoted_price IS NOT NULL",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "text"}
            ]
          }
        }
      }
    },
