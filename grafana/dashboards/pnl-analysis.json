    {
      "id": 5,
      "type": "timeseries",
      "title": "Cumulative P&L Over Time",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT created_at as time, SUM(realized_pnl_usd) OVER (ORDER BY created_at) as \"Cumulative P&L\" FROM executions WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$pair' = '0' OR pair_id = $pair) AND ('$chain' = 'all' OR chain::text = '$chain') AND ('$paper_mode' = 'all' OR is_paper_trade::text = '$paper_mode') AND ('$strategy' = 'all' OR strategy = '$strategy') AND realized_pnl_usd IS NOT NULL ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Cumulative PnL (USD)",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": -1000, "color": "red"},
              {"value": 0, "color": "yellow"},
              {"value": 100, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "min", "max"]
        }
      }
    },
