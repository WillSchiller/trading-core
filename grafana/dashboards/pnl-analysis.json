    {
      "id": 14,
      "type": "barchart",
      "title": "P&L by Trading Pair",
      "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT p.canonical as pair, COALESCE(SUM(e.realized_pnl_usd), 0) as \"P&L\" FROM executions e JOIN pairs p ON p.id = e.pair_id WHERE e.created_at BETWEEN $__timeFrom() AND $__timeTo() AND ('$chain' = 'all' OR e.chain::text = '$chain') AND ('$paper_mode' = 'all' OR e.is_paper_trade::text = '$paper_mode') AND ('$strategy' = 'all' OR e.strategy = '$strategy') AND e.realized_pnl_usd IS NOT NULL GROUP BY p.canonical ORDER BY \"P&L\" DESC LIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "scheme",
