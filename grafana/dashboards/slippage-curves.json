{
  "id": null,
  "uid": "slippage-curves",
  "title": "Slippage Curves - Calibration",
  "tags": ["dislocation-trader", "execution", "slippage"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "xychart",
      "title": "Slippage by Trade Size (Latest Calibration)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 10},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT notional_usd, slippage_bps, direction || ' (' || fee_tier_bps || ' bps fee)' as series FROM latest_slippage_curves WHERE chain = 'base' ORDER BY direction, fee_tier_bps, notional_usd",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "show": "lines+points",
            "lineWidth": 2,
            "lineStyle": {"fill": "solid"},
            "pointSize": {"fixed": 8}
          },
          "unit": "short",
          "decimals": 2
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "buy.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byRegexp", "options": "sell.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {
        "seriesMapping": "manual",
        "dims": {
          "x": "notional_usd"
        },
        "series": [
          {
            "x": "notional_usd",
            "y": "slippage_bps",
            "frame": {"matcher": {"id": "byFrameRefID", "options": "A"}}
          }
        ],
        "tooltip": {"mode": "multi"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right"}
      }
    },
    {
      "id": 2,
      "type": "xychart",
      "title": "Break-Even Threshold by Trade Size",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 10},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT notional_usd, break_even_bps, direction || ' break-even' as series FROM latest_slippage_curves WHERE chain = 'base' ORDER BY direction, notional_usd",
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT notional_usd, recommended_min_spread_bps, direction || ' min spread' as series FROM latest_slippage_curves WHERE chain = 'base' ORDER BY direction, notional_usd",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "show": "lines+points",
            "lineWidth": 2,
            "lineStyle": {"fill": "solid"},
            "pointSize": {"fixed": 6}
          },
          "unit": "short",
          "decimals": 1
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*break-even.*"}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "solid"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*min spread.*"}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash"}}]}
        ]
      },
      "options": {
        "seriesMapping": "manual",
        "dims": {
          "x": "notional_usd"
        },
        "series": [
          {
            "x": "notional_usd",
            "y": "break_even_bps",
            "frame": {"matcher": {"id": "byFrameRefID", "options": "A"}}
          },
          {
            "x": "notional_usd",
            "y": "recommended_min_spread_bps",
            "frame": {"matcher": {"id": "byFrameRefID", "options": "B"}}
          }
        ],
        "tooltip": {"mode": "multi"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right"}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Min Spread @ $500 (Buy)",
      "gridPos": {"x": 0, "y": 10, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(recommended_min_spread_bps, 1) as value FROM latest_slippage_curves WHERE chain = 'base' AND direction = 'buy' AND notional_usd <= 500 ORDER BY notional_usd DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 30, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Min Spread @ $500 (Sell)",
      "gridPos": {"x": 6, "y": 10, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(recommended_min_spread_bps, 1) as value FROM latest_slippage_curves WHERE chain = 'base' AND direction = 'sell' AND notional_usd <= 500 ORDER BY notional_usd DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 30, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Last Calibration",
      "gridPos": {"x": 12, "y": 10, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT MAX(ts) as value FROM slippage_curves",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow"
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Calibration Points",
      "gridPos": {"x": 18, "y": 10, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COUNT(*) as value FROM latest_slippage_curves WHERE chain = 'base'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 1, "color": "yellow"},
              {"value": 10, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Cost Breakdown by Trade Size ($500)",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT direction as \"Direction\", fee_tier_bps as \"Pool Fee (bps)\", ROUND(slippage_bps, 1) as \"Slippage (bps)\", ROUND(gas_bps, 1) as \"Gas (bps)\", ROUND(break_even_bps, 1) as \"Total Break-Even (bps)\" FROM latest_slippage_curves WHERE chain = 'base' AND notional_usd = 500 ORDER BY direction",
          "format": "table"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "normal",
        "groupWidth": 0.7,
        "barWidth": 0.5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Pool Fee (bps)"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "Slippage (bps)"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "Gas (bps)"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]}
        ]
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Calibration Data - All Sizes",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT direction, '$' || notional_usd::int as trade_size, fee_tier_bps as fee_bps, ROUND(slippage_bps, 2) as slip_bps, ROUND(gas_bps, 2) as gas_bps, ROUND(break_even_bps, 1) as break_even, ROUND(recommended_min_spread_bps, 0) as min_spread, ROUND(mid_price, 2) as mid_price, ts FROM latest_slippage_curves WHERE chain = 'base' ORDER BY direction, notional_usd",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "trade_size", "desc": false}]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "min_spread"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 30, "color": "yellow"}, {"value": 50, "color": "red"}]}}]}
        ]
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Slippage Over Time (Historical)",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ts as time, slippage_bps as value, direction || ' $' || notional_usd::int as metric FROM slippage_curves WHERE chain = 'base' AND notional_usd = 500 AND ts BETWEEN $__timeFrom() AND $__timeTo() ORDER BY ts",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 5
          },
          "unit": "short",
          "decimals": 2
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "buy.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byRegexp", "options": "sell.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "min"]}
      }
    }
  ]
}
