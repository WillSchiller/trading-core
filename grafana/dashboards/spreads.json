    {
      "id": 10,
      "type": "table",
      "title": "All Pairs - Current Market Spreads (Diagnostic)",
      "description": "Current spread from raw quotes. May differ from detected spreads due to adaptive polling.",
      "gridPos": {"x": 0, "y": 44, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "WITH latest_cex AS (SELECT DISTINCT ON (r.pair_id) r.pair_id, r.close_mid as cex_mid, r.interval_start as cex_ts, v.name as cex_venue FROM quote_rollups r JOIN venues v ON v.id = r.venue_id WHERE v.venue_type = 'cex' AND r.interval_type = '10s' AND r.interval_start > now() - interval '10 minutes' ORDER BY r.pair_id, r.interval_start DESC), latest_dex AS (SELECT DISTINCT ON (r.pair_id) r.pair_id, r.close_mid as dex_mid, r.interval_start as dex_ts FROM quote_rollups r JOIN venues v ON v.id = r.venue_id WHERE v.venue_type = 'dex' AND r.interval_type = '10s' AND r.interval_start > now() - interval '2 minutes' ORDER BY r.pair_id, r.interval_start DESC) SELECT p.canonical as pair, c.cex_venue, ROUND(c.cex_mid, 6) as cex_mid, ROUND(d.dex_mid, 6) as dex_mid, ROUND((c.cex_mid - d.dex_mid) / NULLIF(c.cex_mid, 0) * 10000, 2) as spread_bps, ROUND(EXTRACT(EPOCH FROM (now() - c.cex_ts)), 1) as cex_age_sec, ROUND(EXTRACT(EPOCH FROM (now() - d.dex_ts)), 1) as dex_age_sec FROM pairs p LEFT JOIN latest_cex c ON c.pair_id = p.id LEFT JOIN latest_dex d ON d.pair_id = p.id WHERE p.is_enabled = true ORDER BY ABS(COALESCE((c.cex_mid - d.dex_mid) / NULLIF(c.cex_mid, 0) * 10000, 0)) DESC",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
