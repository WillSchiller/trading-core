{
  "id": null,
  "uid": "spreads",
  "title": "Spreads - Live",
  "tags": ["dislocation-trader", "spreads"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 6,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "pair",
        "type": "query",
        "label": "Pair",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "definition": "SELECT id as __value, canonical as __text FROM pairs WHERE is_enabled = true ORDER BY canonical",
        "query": "SELECT id as __value, canonical as __text FROM pairs WHERE is_enabled = true ORDER BY canonical",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": "0",
        "current": {},
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "${pair:text} Prices - All Venues (Diagnostic)",
      "description": "Raw quote prices from all venues. Note: DEX quotes may be sparse due to adaptive polling.",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT r.interval_start as time, r.close_mid as value, v.name as metric FROM quote_rollups r JOIN venues v ON v.id = r.venue_id WHERE r.interval_type = '10s' AND r.interval_start BETWEEN $__timeFrom() AND $__timeTo() AND (${pair} = 0 OR r.pair_id = ${pair}) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never"
          },
          "unit": "short",
          "decimals": 6
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "binance"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "coinbase"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "bybit"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]},
          {"matcher": {"id": "byName", "options": "uniswap_v3"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"]}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Detected Spreads Over Time (bps)",
      "description": "Spread values from detected opportunities - the source of truth for actual trading spreads. If no data appears, try selecting 'All' for both Pair and Strategy, or expand the time range.",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT detected_at as time, ABS(spread_bps) as value, CONCAT(strategy, ' - ', direction) as metric FROM opportunities WHERE (${pair} = 0 OR pair_id = ${pair}) AND detected_at BETWEEN $__timeFrom() AND $__timeTo() ORDER BY detected_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "points",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "always",
            "pointSize": 8,
            "thresholdsStyle": {"mode": "line"}
          },
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 15, "color": "yellow"},
              {"value": 30, "color": "orange"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean", "max"]}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latest Detected Spread",
      "description": "Most recent opportunity spread - reflects actual detected trading spread.",
      "gridPos": {"x": 0, "y": 16, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(ABS(spread_bps), 2) as value FROM opportunities WHERE (${pair} = 0 OR pair_id = ${pair}) ORDER BY detected_at DESC LIMIT 1",
          "format": "table"
