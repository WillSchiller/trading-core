    {
      "id": 9,
      "type": "table",
      "title": "Recent Opportunities - ${pair:text}",
      "gridPos": {"x": 0, "y": 36, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COALESCE(opened_at, detected_at) as opened_at, ROUND(EXTRACT(EPOCH FROM (closed_at - COALESCE(opened_at, detected_at)))::numeric, 2) as duration_s, ROUND(COALESCE(max_spread_bps, ABS(spread_bps)), 2) as max_spread_bps, direction, strategy, status, COALESCE(close_reason, '') as close_reason, ROUND(anchor_mid, 2) as cex_price, ROUND(dex_mid, 2) as dex_price FROM opportunities WHERE (${pair} = 0 OR pair_id = ${pair}) ORDER BY COALESCE(opened_at, detected_at) DESC LIMIT 30",
