{
  "id": null,
  "uid": "pm-rust-trades",
  "title": "PM Rust Trades",
  "tags": ["dislocation-trader", "polymarket"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": {"from": "now-7d", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Portfolio (synced from Polymarket)",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 40,
      "type": "stat",
      "title": "Portfolio Value",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT round(coalesce(sum(pnl::float8 * fill_size::float8), 0)::numeric, 2) AS \"Value\" FROM pm_rust_trades WHERE resolved = false AND execution_status = 'filled'",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "text"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 41,
      "type": "stat",
      "title": "Unrealized PnL",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT round(coalesce(sum((pnl::float8 - fill_price::float8) * fill_size::float8), 0)::numeric, 2) AS \"Unrealized\" FROM pm_rust_trades WHERE resolved = false AND execution_status = 'filled' AND pnl IS NOT NULL",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "text"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 42,
      "type": "stat",
      "title": "Realized PnL",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT round(coalesce(sum(real_pnl), 0)::numeric, 2) AS \"Realized\" FROM pm_rust_trades WHERE resolved = true AND execution_status IN ('filled', 'sold')",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "text"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 43,
      "type": "stat",
      "title": "Open Positions",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT count(*) AS \"Open\" FROM pm_rust_trades WHERE resolved = false AND execution_status = 'filled'",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "text"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 44,
      "type": "stat",
      "title": "Win Rate",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT CASE WHEN count(*) = 0 THEN 0 ELSE round(100.0 * count(*) FILTER (WHERE real_pnl > 0) / count(*), 1) END AS \"Win %\" FROM pm_rust_trades WHERE resolved = true AND execution_status IN ('filled', 'sold')",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "color": {"mode": "fixed", "fixedColor": "text"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 45,
      "type": "stat",
      "title": "Avg Latency",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT round(avg(latency_ms)) AS \"ms\" FROM pm_rust_trades WHERE latency_ms IS NOT NULL AND created_at >= $__timeFrom()",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {"unit": "ms", "color": {"mode": "fixed", "fixedColor": "text"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 46,
      "type": "table",
      "title": "Open Positions",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 10},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT market_slug AS market, outcome, fill_price AS avg_price, pnl AS cur_price, fill_size AS shares, round((fill_price * fill_size)::numeric, 2) AS cost, round((pnl::float8 * fill_size::float8)::numeric, 2) AS value, round(((pnl::float8 - fill_price::float8) * fill_size::float8)::numeric, 2) AS unrealized_pnl, model_version, win_score, cal_prob, kelly_size FROM pm_rust_trades WHERE resolved = false AND execution_status = 'filled' ORDER BY (pnl::float8 - fill_price::float8) * fill_size::float8 DESC LIMIT 100",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "avg_price"}, "properties": [{"id": "decimals", "value": 3}]},
          {"matcher": {"id": "byName", "options": "cur_price"}, "properties": [{"id": "decimals", "value": 3}]},
          {"matcher": {"id": "byName", "options": "shares"}, "properties": [{"id": "decimals", "value": 1}]},
          {"matcher": {"id": "byName", "options": "cost"}, "properties": [{"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "value"}, "properties": [{"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "unrealized_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "win_score"}, "properties": [{"id": "decimals", "value": 3}]},
          {"matcher": {"id": "byName", "options": "cal_prob"}, "properties": [{"id": "decimals", "value": 3}]},
          {"matcher": {"id": "byName", "options": "kelly_size"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": true, "reducer": ["sum"], "fields": ["cost", "value", "unrealized_pnl"]}}
    },
    {
      "id": 20,
      "type": "row",
      "title": "Performance",
      "gridPos": {"x": 0, "y": 15, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Cumulative Realized PnL",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT resolved_at AS time, sum(real_pnl) OVER (ORDER BY resolved_at) AS value FROM pm_rust_trades WHERE resolved = true AND resolved_at IS NOT NULL AND execution_status IN ('filled', 'sold') ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 5, "showPoints": "always"}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Latency Over Time",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT created_at AS time, latency_ms AS value, execution_status AS metric FROM pm_rust_trades WHERE latency_ms IS NOT NULL AND created_at BETWEEN $__timeFrom() AND $__timeTo() ORDER BY created_at",
        "format": "time_series"
      }],
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "points", "pointSize": 6, "fillOpacity": 0}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 47,
      "type": "row",
      "title": "ML Model Comparison",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 48,
      "type": "table",
      "title": "ML Would-Bet vs Would-Skip (resolved trades only)",
      "gridPos": {"x": 0, "y": 25, "w": 24, "h": 6},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT CASE WHEN kelly_size > 0 THEN 'ML would bet' ELSE 'ML would skip' END AS ml_action, count(*) AS trades, round(100.0 * count(*) FILTER (WHERE real_pnl > 0) / NULLIF(count(*), 0), 1) AS win_rate_pct, round(coalesce(avg(real_pnl), 0)::numeric, 2) AS avg_pnl, round(coalesce(sum(real_pnl), 0)::numeric, 2) AS total_pnl FROM pm_rust_trades WHERE resolved = true AND execution_status IN ('filled', 'sold') GROUP BY 1 ORDER BY 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "avg_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}]},
          {"matcher": {"id": "byName", "options": "total_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}}
    },
    {
      "id": 23,
      "type": "row",
      "title": "Funnel & History",
      "gridPos": {"x": 0, "y": 31, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 24,
      "type": "table",
      "title": "Outcome Breakdown",
      "gridPos": {"x": 0, "y": 32, "w": 12, "h": 6},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT execution_status, count(*) AS count, round(100.0 * count(*) / NULLIF((SELECT count(*) FROM pm_rust_trades), 0), 1) AS pct FROM pm_rust_trades GROUP BY execution_status ORDER BY count DESC",
        "format": "table"
      }],
      "options": {"showHeader": true, "footer": {"show": false}}
    },
    {
      "id": 25,
      "type": "barchart",
      "title": "Attempts per Hour",
      "gridPos": {"x": 12, "y": 32, "w": 12, "h": 6},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT date_trunc('hour', created_at) AS time, count(*) FILTER (WHERE execution_status IN ('filled', 'pending')) AS filled, count(*) FILTER (WHERE execution_status = 'no_fill') AS no_fill, count(*) FILTER (WHERE execution_status = 'balance_error') AS balance_error FROM pm_rust_trades WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() GROUP BY date_trunc('hour', created_at) ORDER BY time",
        "format": "table"
      }],
      "fieldConfig": {"defaults": {}},
      "options": {"xField": "time", "stacking": "normal", "barWidth": 0.8}
    },
    {
      "id": 31,
      "type": "table",
      "title": "Recent Trades",
      "gridPos": {"x": 0, "y": 38, "w": 24, "h": 10},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT created_at, model_version, execution_status, market_slug, outcome, latency_ms, fill_price, fill_size, real_pnl, resolved FROM pm_rust_trades WHERE execution_status IN ('filled', 'sold', 'pending') ORDER BY created_at DESC LIMIT 50",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "real_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "fill_price"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "fill_size"}, "properties": [{"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "created_at"}, "properties": [{"id": "custom.width", "value": 180}]},
          {"matcher": {"id": "byName", "options": "latency_ms"}, "properties": [{"id": "unit", "value": "ms"}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "created_at", "desc": true}]}
    }
  ]
}
