{
  "id": null,
  "uid": "polymarket-copy",
  "title": "Polymarket Copy Trader",
  "tags": ["dislocation-trader", "polymarket"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {"from": "now-7d", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Shadow Performance (All-Time)",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Shadow Total PnL",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND(COALESCE(SUM(pnl_if_copied), 0)::numeric, 2) AS \"PnL\" FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Shadow Win Rate",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE pnl_if_copied > 0)::numeric / NULLIF(COUNT(*), 0) * 100, 1) AS \"Win %\" FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 55, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Avg PnL/Trade",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND((SUM(pnl_if_copied) / NULLIF(COUNT(*), 0))::numeric, 4) AS \"Avg\" FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 4,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Total Shadow Trades",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*)::int AS \"Trades\" FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "blue"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Max Drawdown",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "WITH cum AS (SELECT resolved_at, SUM(pnl_if_copied) OVER (ORDER BY resolved_at) AS equity FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0), peak AS (SELECT resolved_at, equity, MAX(equity) OVER (ORDER BY resolved_at) AS hw FROM cum) SELECT ROUND(MIN(equity - hw)::numeric, 2) AS \"Drawdown\" FROM peak",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Profit Factor",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND((SUM(pnl_if_copied) FILTER (WHERE pnl_if_copied > 0) / NULLIF(ABS(SUM(pnl_if_copied) FILTER (WHERE pnl_if_copied < 0)), 0))::numeric, 2) AS \"PF\" FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "yellow"}, {"value": 1.5, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 105,
      "type": "row",
      "title": "Risk Status",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Exposure",
      "gridPos": {"x": 0, "y": 6, "w": 5, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND(COALESCE(SUM(size * avg_entry), 0)::numeric, 2) AS \"Exposure\" FROM pm_positions WHERE status = 'open'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 400, "color": "yellow"}, {"value": 500, "color": "red"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Daily PnL (Realized)",
      "gridPos": {"x": 5, "y": 6, "w": 5, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND(COALESCE(SUM(realized_pnl), 0)::numeric, 2) AS \"PnL\" FROM pm_positions WHERE status = 'closed' AND closed_at >= (NOW() AT TIME ZONE 'UTC')::date",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open Markets",
      "gridPos": {"x": 10, "y": 6, "w": 4, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(DISTINCT condition_id)::int AS \"Markets\" FROM pm_positions WHERE status = 'open'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "blue"}, {"value": 8, "color": "yellow"}, {"value": 10, "color": "red"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Kill Switch",
      "gridPos": {"x": 14, "y": 6, "w": 5, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT CASE WHEN EXISTS(SELECT 1 FROM pm_kill_switch_events WHERE triggered_at >= NOW() - INTERVAL '24h') THEN 'TRIGGERED' ELSE 'OK' END AS \"Status\"",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"OK": {"text": "OK", "color": "green"}, "TRIGGERED": {"text": "TRIGGERED", "color": "red"}}}
          ]
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Copy Eligible Traders",
      "gridPos": {"x": 19, "y": 6, "w": 5, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*)::int AS \"Eligible\" FROM pm_tracked_traders WHERE enabled = true AND copy_eligible = true",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "yellow"}, {"value": 3, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 106,
      "type": "row",
      "title": "Shadow Equity Curve",
      "gridPos": {"x": 0, "y": 10, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Cumulative Shadow PnL (all traders)",
      "gridPos": {"x": 0, "y": 11, "w": 12, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT resolved_at AS time, SUM(pnl_if_copied) OVER (ORDER BY resolved_at) AS \"Cumulative PnL\" FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0 ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "fixed", "fixedColor": "green"},
          "custom": {"fillOpacity": 10, "lineWidth": 2}
        }
      },
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Daily Shadow PnL",
      "gridPos": {"x": 12, "y": 11, "w": 12, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT date_trunc('day', resolved_at) AS time, ROUND(SUM(pnl_if_copied)::numeric, 2)::float AS \"Daily PnL\", COUNT(*)::int AS \"Trades\" FROM pm_shadow_trades WHERE resolved = true AND side = 'BUY' AND our_entry_price > 0 AND resolved_at >= NOW() - INTERVAL '30d' GROUP BY 1 ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "custom": {"fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars"}
        }
      },
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 107,
      "type": "row",
      "title": "Trader Leaderboard (Shadow Performance)",
      "gridPos": {"x": 0, "y": 19, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 32,
      "type": "table",
      "title": "Trader Performance (Resolved Shadow Trades)",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT s.trader_alias AS \"trader\", COUNT(*) AS \"trades\", COUNT(*) FILTER (WHERE s.pnl_if_copied > 0) AS \"wins\", ROUND((COUNT(*) FILTER (WHERE s.pnl_if_copied > 0)::numeric / NULLIF(COUNT(*), 0) * 100), 1) AS \"win_rate_%\", ROUND(SUM(s.pnl_if_copied)::numeric, 2) AS \"total_pnl\", ROUND((SUM(s.pnl_if_copied) / NULLIF(COUNT(*), 0))::numeric, 4) AS \"avg_pnl\", ROUND((SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied > 0) / NULLIF(ABS(SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied < 0)), 0))::numeric, 2) AS \"profit_factor\", COALESCE(t.copy_eligible, false) AS \"copy_eligible\" FROM pm_shadow_trades s LEFT JOIN pm_tracked_traders t ON s.trader_address = t.address WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0 GROUP BY s.trader_alias, t.copy_eligible ORDER BY SUM(s.pnl_if_copied) DESC",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "total_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "avg_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 4}]}
        ]
      },
      "options": {"showHeader": true, "sortBy": [{"displayName": "total_pnl", "desc": true}]}
    },
    {
      "id": 108,
      "type": "row",
      "title": "Open Positions",
      "gridPos": {"x": 0, "y": 28, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 7,
      "type": "table",
      "title": "Open Positions",
      "gridPos": {"x": 0, "y": 29, "w": 24, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT market_slug AS \"market\", outcome, side, size::float, avg_entry::float AS \"entry\", current_price::float AS \"current\", unrealized_pnl::float AS \"unrealized_pnl\", paper, opened_at FROM pm_positions WHERE status = 'open' ORDER BY opened_at DESC LIMIT 50",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "entry"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "current"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "unrealized_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]}
        ]
      },
      "options": {"showHeader": true, "sortBy": [{"displayName": "opened_at", "desc": true}]}
    },
    {
      "id": 109,
      "type": "row",
      "title": "Realized PnL & Copy Trades",
      "gridPos": {"x": 0, "y": 37, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cumulative Realized PnL (Copy Trades)",
      "gridPos": {"x": 0, "y": 38, "w": 12, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT closed_at AS time, SUM(realized_pnl::float) OVER (ORDER BY closed_at) AS \"Cumulative PnL\" FROM pm_positions WHERE status = 'closed' AND closed_at IS NOT NULL ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "custom": {"fillOpacity": 10, "lineWidth": 2}
        }
      },
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Shadow Trades Volume (hourly)",
      "gridPos": {"x": 12, "y": 38, "w": 12, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT date_trunc('hour', observed_at) AS time, COUNT(*)::int AS \"Trades\", ROUND(SUM(our_size)::numeric, 2)::float AS \"Size USD\" FROM pm_shadow_trades WHERE observed_at >= NOW() - INTERVAL '7d' AND side = 'BUY' GROUP BY 1 ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {"fillOpacity": 20, "lineWidth": 2, "drawStyle": "bars"}
        }
      },
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 110,
      "type": "row",
      "title": "Recent Shadow Trades",
      "gridPos": {"x": 0, "y": 46, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 10,
      "type": "table",
      "title": "Recent Shadow Trades",
      "gridPos": {"x": 0, "y": 47, "w": 24, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT observed_at, trader_alias AS \"trader\", market_slug AS \"market\", outcome, side, size::float AS \"trader_size\", price::float, our_size::float, our_entry_price::float AS \"entry\", current_price::float AS \"current\", pnl_if_copied::float AS \"pnl\", resolved FROM pm_shadow_trades WHERE side = 'BUY' ORDER BY observed_at DESC LIMIT 50",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "price"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "entry"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "current"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]}
        ]
      },
      "options": {"showHeader": true, "sortBy": [{"displayName": "observed_at", "desc": true}]}
    }
  ]
}
