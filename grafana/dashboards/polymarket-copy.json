    {
      "id": 100,
      "type": "row",
      "title": "Shadow Performance — Eligible Traders Only",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Total PnL",
      "description": "PnL from copy-eligible traders only",
      "gridPos": {"x": 0, "y": 5, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(s.pnl_if_copied), 0)::numeric, 2) AS \"PnL\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 26,
      "type": "stat",
      "title": "Return on Bankroll",
      "description": "Total PnL / $500 bankroll",
      "gridPos": {"x": 4, "y": 5, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND((COALESCE(SUM(s.pnl_if_copied), 0) / 500 * 100)::numeric, 1) AS \"ROI %\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "yellow"}, {"value": 50, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Win Rate",
      "gridPos": {"x": 8, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE s.pnl_if_copied > 0)::numeric / NULLIF(COUNT(*), 0) * 100, 1) AS \"Win %\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 55, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Avg PnL/Trade",
      "gridPos": {"x": 11, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND((SUM(s.pnl_if_copied) / NULLIF(COUNT(*), 0))::numeric, 4) AS \"Avg\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Trades",
      "gridPos": {"x": 14, "y": 5, "w": 2, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT COUNT(*)::int AS \"N\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "blue"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Profit Factor",
      "description": "Gross wins / gross losses. >1.5 is good.",
      "gridPos": {"x": 16, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND((SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied > 0) / NULLIF(ABS(SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied < 0)), 0))::numeric, 2) AS \"PF\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0", "format": "table"}],
      "fieldConfig": {"defaults": {"decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "yellow"}, {"value": 1.5, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Max Drawdown",
      "description": "Largest peak-to-trough decline (eligible traders)",
      "gridPos": {"x": 19, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "WITH cum AS (SELECT s.resolved_at, SUM(s.pnl_if_copied) OVER (ORDER BY s.resolved_at) AS equity FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0), peak AS (SELECT equity, MAX(equity) OVER (ORDER BY resolved_at) AS hw FROM cum) SELECT ROUND(MIN(equity - hw)::numeric, 2) AS \"DD\" FROM peak", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 27,
      "type": "stat",
      "title": "DD % of Bankroll",
      "description": "Max drawdown as % of $500 bankroll",
      "gridPos": {"x": 22, "y": 5, "w": 2, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "WITH cum AS (SELECT s.resolved_at, SUM(s.pnl_if_copied) OVER (ORDER BY s.resolved_at) AS equity FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0), peak AS (SELECT equity, MAX(equity) OVER (ORDER BY resolved_at) AS hw FROM cum) SELECT ROUND((MIN(equity - hw) / 500 * 100)::numeric, 1) AS \"DD %\" FROM peak", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },

    {
      "id": 105,
      "type": "row",
      "title": "Live Risk Status",
      "gridPos": {"x": 0, "y": 9, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Current Exposure",
      "gridPos": {"x": 0, "y": 10, "w": 5, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(size * avg_entry), 0)::numeric, 2) AS \"Exposure\" FROM pm_positions WHERE status = 'open'", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 400, "color": "yellow"}, {"value": 500, "color": "red"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Today Realized PnL",
      "gridPos": {"x": 5, "y": 10, "w": 5, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(realized_pnl), 0)::numeric, 2) AS \"PnL\" FROM pm_positions WHERE status = 'closed' AND closed_at >= (NOW() AT TIME ZONE 'UTC')::date", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open Markets",
      "gridPos": {"x": 10, "y": 10, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT COUNT(DISTINCT condition_id)::int AS \"Markets\" FROM pm_positions WHERE status = 'open'", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "blue"}, {"value": 8, "color": "yellow"}, {"value": 10, "color": "red"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Kill Switch",
      "gridPos": {"x": 14, "y": 10, "w": 5, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT CASE WHEN EXISTS(SELECT 1 FROM pm_kill_switch_events WHERE triggered_at >= NOW() - INTERVAL '24h') THEN 1 ELSE 0 END AS \"Status\"", "format": "table"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "OK", "color": "green"}, "1": {"text": "TRIGGERED", "color": "red"}}}], "color": {"mode": "fixed", "fixedColor": "green"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Copy Eligible Traders",
      "gridPos": {"x": 19, "y": 10, "w": 5, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT COUNT(*)::int AS \"Eligible\" FROM pm_tracked_traders WHERE enabled = true AND copy_eligible = true", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "yellow"}, {"value": 3, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },

    {
      "id": 106,
      "type": "row",
      "title": "Equity Curves (Eligible Traders)",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Shadow Equity Curve (eligible traders)",
      "description": "Cumulative PnL from copy-eligible traders only",
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT s.resolved_at AS time, SUM(s.pnl_if_copied) OVER (ORDER BY s.resolved_at) AS \"Equity\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0 ORDER BY time", "format": "time_series"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "green"}, "custom": {"fillOpacity": 10, "lineWidth": 2}}},
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Daily Shadow PnL + Drawdown",
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT date_trunc('day', s.resolved_at) AS time, ROUND(SUM(s.pnl_if_copied)::numeric, 2)::float AS \"Daily PnL\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0 GROUP BY 1 ORDER BY time", "format": "time_series"},
        {"refId": "B", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "WITH daily AS (SELECT date_trunc('day', s.resolved_at) AS day, SUM(s.pnl_if_copied) AS pnl FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0 GROUP BY 1), cum AS (SELECT day, SUM(pnl) OVER (ORDER BY day) AS equity FROM daily), dd AS (SELECT day AS time, equity - MAX(equity) OVER (ORDER BY day) AS \"Drawdown\" FROM cum) SELECT * FROM dd ORDER BY time", "format": "time_series"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "custom": {"fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars"}},
        "overrides": [{"matcher": {"id": "byName", "options": "Drawdown"}, "properties": [{"id": "custom.drawStyle", "value": "line"}, {"id": "custom.fillOpacity", "value": 10}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}]
      },
      "options": {"tooltip": {"mode": "multi"}}
    },

    {
      "id": 107,
      "type": "row",
      "title": "Trader Leaderboard",
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 32,
      "type": "table",
      "title": "All Traders Shadow Performance",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 8},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT s.trader_alias AS \"trader\", COUNT(*) AS \"trades\", COUNT(*) FILTER (WHERE s.pnl_if_copied > 0) AS \"wins\", ROUND((COUNT(*) FILTER (WHERE s.pnl_if_copied > 0)::numeric / NULLIF(COUNT(*), 0) * 100), 1) AS \"win_%\", ROUND(SUM(s.pnl_if_copied)::numeric, 2) AS \"total_pnl\", ROUND((SUM(s.pnl_if_copied) / NULLIF(COUNT(*), 0))::numeric, 4) AS \"avg_pnl\", ROUND((SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied > 0) / NULLIF(ABS(SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied < 0)), 0))::numeric, 2) AS \"profit_factor\", COALESCE(t.copy_eligible, false) AS \"copy_eligible\" FROM pm_shadow_trades s LEFT JOIN pm_tracked_traders t ON s.trader_address = t.address WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0 GROUP BY s.trader_alias, t.copy_eligible HAVING COUNT(*) >= 2 ORDER BY SUM(s.pnl_if_copied) DESC", "format": "table"}],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "total_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "avg_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 4}]}
        ]
      },
      "options": {"showHeader": true, "sortBy": [{"displayName": "total_pnl", "desc": true}]}
    },

    {
      "id": 108,
      "type": "row",
      "title": "Open Positions",
      "gridPos": {"x": 0, "y": 32, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 7,
      "type": "table",
      "title": "Open Positions",
      "gridPos": {"x": 0, "y": 33, "w": 24, "h": 7},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT market_slug AS \"market\", outcome, side, size::float, avg_entry::float AS \"entry\", current_price::float AS \"current\", unrealized_pnl::float AS \"unrealized_pnl\", paper, opened_at FROM pm_positions WHERE status = 'open' ORDER BY opened_at DESC LIMIT 50", "format": "table"}],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "entry"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "current"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "unrealized_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]}
        ]
      },
      "options": {"showHeader": true, "sortBy": [{"displayName": "opened_at", "desc": true}]}
    },

    {
      "id": 109,
      "type": "row",
      "title": "Trade Activity",
      "gridPos": {"x": 0, "y": 40, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Realized PnL (Actual Copy Trades)",
      "description": "Actual money made/lost from copy trades placed",
      "gridPos": {"x": 0, "y": 41, "w": 12, "h": 8},
