      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT 2 AS \"Mode\"", "format": "table"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"1": {"text": "PAPER", "color": "yellow"}, "2": {"text": "LIVE", "color": "green"}}}], "color": {"mode": "fixed", "fixedColor": "yellow"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },

    {
      "id": 100,
      "type": "row",
      "title": "Performance — Paper vs Real",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 310,
      "type": "stat",
      "title": "Net Deposited",
      "description": "Total deposits minus withdrawals",
      "gridPos": {"x": 0, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(SUM(CASE WHEN type = 'deposit' THEN amount ELSE -amount END)::numeric, 2) AS \"Deposited\" FROM pm_deposits", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "text"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 312,
      "type": "stat",
      "title": "Realized PnL",
      "description": "PnL from resolved + sold trades (DB tracked)",
      "gridPos": {"x": 3, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(real_pnl), 0)::numeric, 2) AS \"PnL\" FROM pm_all_live_trades WHERE resolved = true AND execution_status IN ('filled', 'sold')", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 311,
      "type": "stat",
      "title": "Filled",
      "description": "Number of confirmed CLOB fills",
      "gridPos": {"x": 6, "y": 5, "w": 2, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT COUNT(*)::int AS \"N\" FROM pm_all_live_trades WHERE execution_status IN ('filled', 'sold')", "format": "table"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Paper PnL (Hypothetical)",
      "description": "Hypothetical PnL if all trades filled at trader price — NOT real money",
      "gridPos": {"x": 8, "y": 5, "w": 2, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(pnl), 0)::numeric, 2) AS \"PnL\" FROM pm_all_live_trades WHERE resolved = true", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Trades",
      "gridPos": {"x": 10, "y": 5, "w": 2, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT COUNT(*)::int AS \"N\" FROM pm_all_live_trades WHERE resolved = true", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "blue"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Win Rate",
      "gridPos": {"x": 12, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COUNT(*) FILTER (WHERE pnl > 0)::numeric / NULLIF(COUNT(*), 0) * 100, 1) AS \"Win %\" FROM pm_all_live_trades WHERE resolved = true", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 55, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Avg PnL/Trade",
      "gridPos": {"x": 15, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND((SUM(pnl) / NULLIF(COUNT(*), 0))::numeric, 2) AS \"Avg\" FROM pm_all_live_trades WHERE resolved = true", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Profit Factor",
      "gridPos": {"x": 18, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND((SUM(pnl) FILTER (WHERE pnl > 0) / NULLIF(ABS(SUM(pnl) FILTER (WHERE pnl < 0)), 0))::numeric, 2) AS \"PF\" FROM pm_all_live_trades WHERE resolved = true", "format": "table"}],
      "fieldConfig": {"defaults": {"decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "yellow"}, {"value": 1.5, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Max DD",
      "gridPos": {"x": 21, "y": 5, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "WITH cum AS (SELECT observed_at, SUM(pnl) OVER (ORDER BY observed_at) AS equity FROM pm_all_live_trades WHERE resolved = true), peak AS (SELECT equity, MAX(equity) OVER (ORDER BY observed_at) AS hw FROM cum) SELECT ROUND(MIN(equity - hw)::numeric, 2) AS \"DD\" FROM peak", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },

    {
      "id": 105,
      "type": "row",
      "title": "Live Risk Status",
      "gridPos": {"x": 0, "y": 9, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Current Exposure",
      "gridPos": {"x": 0, "y": 10, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(our_size * our_entry_price), 0)::numeric, 2) AS \"Exposure\" FROM pm_all_live_trades WHERE resolved = false", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 400, "color": "yellow"}, {"value": 500, "color": "red"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Today Realized",
      "gridPos": {"x": 4, "y": 10, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(pnl), 0)::numeric, 2) AS \"PnL\" FROM pm_all_live_trades WHERE resolved = true AND resolved_at::date = (NOW() AT TIME ZONE 'UTC')::date", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Unrealized PnL",
      "gridPos": {"x": 8, "y": 10, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(COALESCE(SUM(pnl), 0)::numeric, 2) AS \"PnL\" FROM pm_all_live_trades WHERE resolved = false", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 0, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open Markets",
      "gridPos": {"x": 12, "y": 10, "w": 3, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT COUNT(DISTINCT condition_id)::int AS \"Markets\" FROM pm_all_live_trades WHERE resolved = false", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "blue"}, {"value": 8, "color": "yellow"}, {"value": 10, "color": "red"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Kill Switch",
      "gridPos": {"x": 15, "y": 10, "w": 4, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT CASE WHEN EXISTS(SELECT 1 FROM pm_kill_switch_events WHERE triggered_at >= NOW() - INTERVAL '24h') THEN 1 ELSE 0 END AS \"Status\"", "format": "table"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "OK", "color": "green"}, "1": {"text": "TRIGGERED", "color": "red"}}}], "color": {"mode": "fixed", "fixedColor": "green"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Eligible Traders",
      "gridPos": {"x": 19, "y": 10, "w": 5, "h": 4},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT COUNT(*)::int AS \"Eligible\" FROM pm_tracked_traders WHERE enabled = true AND copy_eligible = true", "format": "table"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "yellow"}, {"value": 3, "color": "green"}]}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },

    {
      "id": 106,
      "type": "row",
      "title": "Equity Curves (Eligible Traders)",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Live Equity Curve",
      "description": "Cumulative PnL from trades observed after qualification only",
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT observed_at AS time, SUM(pnl) OVER (ORDER BY observed_at) AS \"Equity\" FROM pm_all_live_trades WHERE resolved = true ORDER BY time", "format": "time_series"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "green"}, "custom": {"fillOpacity": 10, "lineWidth": 2}}},
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Daily Shadow PnL + Drawdown",
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT date_trunc('day', resolved_at) AS time, ROUND(SUM(pnl)::numeric, 2)::float AS \"Daily PnL\" FROM pm_all_live_trades WHERE resolved = true GROUP BY 1 ORDER BY time", "format": "time_series"},
        {"refId": "B", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "WITH daily AS (SELECT date_trunc('day', resolved_at) AS day, SUM(pnl) AS pnl FROM pm_all_live_trades WHERE resolved = true GROUP BY 1), cum AS (SELECT day, SUM(pnl) OVER (ORDER BY day) AS equity FROM daily), dd AS (SELECT day AS time, equity - MAX(equity) OVER (ORDER BY day) AS \"Drawdown\" FROM cum) SELECT time, \"Drawdown\" FROM dd ORDER BY time", "format": "time_series"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "decimals": 2, "custom": {"fillOpacity": 30, "lineWidth": 2, "drawStyle": "bars"}},
        "overrides": [{"matcher": {"id": "byName", "options": "Drawdown"}, "properties": [{"id": "custom.drawStyle", "value": "line"}, {"id": "custom.fillOpacity", "value": 10}, {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}]
      },
      "options": {"tooltip": {"mode": "multi"}}
    },

    {
      "id": 107,
      "type": "row",
      "title": "Trader Leaderboard",
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 32,
      "type": "table",
      "title": "All Traders Shadow Performance",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 8},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT s.trader_alias AS \"trader\", COUNT(*) AS \"trades\", COUNT(DISTINCT DATE(to_timestamp(s.trader_timestamp/1000)))::int AS \"days\", MIN(to_timestamp(s.trader_timestamp/1000))::date AS \"first_trade\", COUNT(*) FILTER (WHERE s.pnl_if_copied > 0) AS \"wins\", ROUND((COUNT(*) FILTER (WHERE s.pnl_if_copied > 0)::numeric / NULLIF(COUNT(*), 0) * 100), 1) AS \"win_%\", ROUND(SUM(s.pnl_if_copied)::numeric, 2) AS \"total_pnl\", ROUND((SUM(s.pnl_if_copied) / NULLIF(COUNT(*), 0))::numeric, 2) AS \"avg_pnl\", ROUND((SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied > 0) / NULLIF(ABS(SUM(s.pnl_if_copied) FILTER (WHERE s.pnl_if_copied < 0)), 0))::numeric, 2) AS \"profit_factor\", COALESCE(t.copy_eligible, false) AS \"eligible\" FROM pm_shadow_trades s LEFT JOIN pm_tracked_traders t ON s.trader_address = t.address WHERE s.resolved = true AND s.side = 'BUY' AND s.our_entry_price > 0 GROUP BY s.trader_alias, t.copy_eligible HAVING COUNT(*) >= 10 ORDER BY SUM(s.pnl_if_copied) DESC", "format": "table"}],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "total_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "avg_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 4}]}
        ]
      },
      "options": {"showHeader": true, "sortBy": [{"displayName": "total_pnl", "desc": true}]}
    },

    {
      "id": 108,
      "type": "row",
      "title": "Open Positions",
      "gridPos": {"x": 0, "y": 32, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 7,
      "type": "table",
      "title": "Open Positions",
      "gridPos": {"x": 0, "y": 33, "w": 24, "h": 7},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT trader_alias AS \"trader\", market_slug AS \"market\", outcome, ROUND(our_size::numeric, 1)::float AS \"size\", ROUND(our_entry_price::numeric, 4)::float AS \"entry\", ROUND(current_price::numeric, 4)::float AS \"current\", ROUND(pnl::numeric, 2)::float AS \"pnl\", observed_at FROM pm_all_live_trades WHERE resolved = false ORDER BY observed_at DESC LIMIT 50", "format": "table"}],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "entry"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "current"}, "properties": [{"id": "decimals", "value": 4}]},
          {"matcher": {"id": "byName", "options": "unrealized_pnl"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 2}]}
        ]
      },
      "options": {"showHeader": true, "sortBy": [{"displayName": "opened_at", "desc": true}]}
    },

    {
      "id": 109,
      "type": "row",
      "title": "Trade Activity",
      "gridPos": {"x": 0, "y": 40, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Realized PnL (Actual Copy Trades)",
      "description": "Actual money made/lost from copy trades placed",
      "gridPos": {"x": 0, "y": 41, "w": 12, "h": 8},
      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT resolved_at AS time, SUM(pnl::float) OVER (ORDER BY resolved_at) AS \"Cumulative PnL\" FROM pm_all_live_trades WHERE resolved = true AND resolved_at IS NOT NULL ORDER BY time", "format": "time_series"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "orange"}, "custom": {"fillOpacity": 10, "lineWidth": 2}}},
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Shadow Trade Volume (hourly)",
