      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "orange"}}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 44,
      "type": "stat",
      "title": "Avg Trade Size",
