      "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT ROUND(AVG(s.our_size)::numeric, 2) AS \"Avg\" FROM pm_shadow_trades s JOIN pm_tracked_traders t ON s.trader_address = t.address AND t.copy_eligible = true WHERE s.side = 'BUY' AND s.our_size > 0", "format": "table"}],
