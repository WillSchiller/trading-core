        {"refId": "B", "datasource": {"type": "postgres", "uid": "postgresql"}, "rawSql": "SELECT resolved_at AS time, SUM(real_pnl::float) OVER (ORDER BY resolved_at) AS \"Live\" FROM pm_all_live_trades WHERE resolved = true AND real_pnl IS NOT NULL ORDER BY time", "format": "time_series"}
