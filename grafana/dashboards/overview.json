{
  "id": null,
  "uid": "overview",
  "title": "Overview - Live Monitoring",
  "tags": ["dislocation-trader", "live"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "pair",
        "type": "query",
        "label": "Pair",
        "datasource": {
          "type": "postgres",
          "uid": "postgresql"
        },
        "definition": "SELECT id as __value, canonical as __text FROM pairs WHERE is_enabled = true ORDER BY canonical",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": "0",
        "current": {},
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 9,
      "type": "stat",
      "title": "Last Quote",
      "description": "Seconds since last quote received. Up to 25s is normal during adaptive polling. YELLOW (25-60s) = conserve mode (quiet market). ORANGE/RED = actual staleness issue.",
      "gridPos": {"x": 10, "y": 0, "w": 4, "h": 3},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now() - MAX(ts)))::integer as value FROM quotes_raw",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 25, "color": "yellow"},
              {"value": 60, "color": "orange"},
              {"value": 120, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "TRADING MODE",
      "description": "Shows whether system is in PAPER (simulation) or LIVE (real money) mode",
      "gridPos": {"x": 0, "y": 0, "w": 3, "h": 3},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT 'PAPER' as status",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": "/^status$/"
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "PAPER": {
                  "text": "PAPER",
                  "color": "green",
                  "index": 0
                },
                "LIVE": {
                  "text": "LIVE",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"}
            ]
          },
          "custom": {
            "neutral": "green"
          }
        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Risk Status",
      "description": "Current risk state - HALTED means trading is stopped",
      "gridPos": {"x": 3, "y": 0, "w": 4, "h": 3},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT CASE WHEN is_halted THEN 'HALTED' ELSE 'ACTIVE' END as status, open_exposure_usd, trades_last_hour FROM risk_state WHERE chain = 'base' ORDER BY updated_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": "/^status$/"
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "HALTED": {
                  "text": "HALTED",
                  "color": "red",
                  "index": 0
                },
                "ACTIVE": {
                  "text": "ACTIVE",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Exposure (USD)",
      "description": "Current open exposure in USD (max $5000)",
      "gridPos": {"x": 7, "y": 0, "w": 3, "h": 3},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(open_exposure_usd, 2) as value FROM risk_state WHERE chain = 'base' ORDER BY updated_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 2500, "color": "yellow"},
              {"value": 4000, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "SYSTEM STATUS",
      "description": "Overall system health. GREEN=Active. YELLOW=Conserving (quiet market). ORANGE=Stale data. RED=Offline.",
      "gridPos": {"x": 14, "y": 0, "w": 4, "h": 3},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "WITH status_check AS (SELECT CASE WHEN NOT EXISTS (SELECT 1 FROM connector_health WHERE ws_connected = true) THEN 'OFFLINE' WHEN EXTRACT(EPOCH FROM (now() - (SELECT MAX(ts) FROM quotes_raw))) > 60 THEN 'STALE' WHEN EXTRACT(EPOCH FROM (now() - (SELECT MAX(ts) FROM quotes_raw WHERE venue_id IN (SELECT id FROM venues WHERE venue_type = 'dex')))) > 25 THEN 'CONSERVING' ELSE 'ACTIVE' END as status) SELECT status FROM status_check",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": "/^status$/"
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "ACTIVE": {
                  "text": "ACTIVE",
                  "color": "green",
                  "index": 0
                },
                "CONSERVING": {
                  "text": "CONSERVING",
                  "color": "yellow",
                  "index": 1
                },
                "STALE": {
                  "text": "STALE",
                  "color": "orange",
                  "index": 2
                },
                "OFFLINE": {
                  "text": "OFFLINE",
                  "color": "red",
                  "index": 3
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "MARKET ACTIVITY",
      "description": "Current spread activity level. BUSY=Near threshold. QUIET=Well below threshold (adaptive polling conserving RPC).",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 3},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT CASE WHEN spread_bps >= 13.5 THEN 'BUSY' WHEN spread_bps >= 7.5 THEN 'MODERATE' WHEN spread_bps >= 4.5 THEN 'QUIET' ELSE 'VERY QUIET' END as activity FROM (SELECT COALESCE(ABS(MAX(o.spread_bps)), 0) as spread_bps FROM opportunities o WHERE o.detected_at > now() - interval '15 minutes') t",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": "/^activity$/"
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "BUSY": {
                  "text": "BUSY",
                  "color": "green",
                  "index": 0
                },
                "MODERATE": {
                  "text": "MODERATE",
                  "color": "yellow",
                  "index": 1
                },
                "QUIET": {
                  "text": "QUIET",
                  "color": "blue",
                  "index": 2
                },
                "VERY QUIET": {
                  "text": "VERY QUIET",
                  "color": "purple",
                  "index": 3
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Live Quote Prices (All Venues)",
      "gridPos": {"x": 0, "y": 3, "w": 24, "h": 10},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT qr.interval_start as time, v.name as metric, qr.close_mid as value FROM quote_rollups qr JOIN venues v ON v.id = qr.venue_id JOIN pairs p ON p.id = qr.pair_id WHERE qr.interval_start BETWEEN $__timeFrom() AND $__timeTo() AND qr.interval_type = '1s' AND (${pair} = 0 OR p.id = ${pair}) AND qr.close_mid IS NOT NULL ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 0,
            "gradientMode": "none",
            "spanNulls": 60000,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Price (USD)",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "binance"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "coinbase"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "bybit"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "uniswap_v3"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
              {"id": "custom.lineWidth", "value": 3}
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean"]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Real-Time Spread (Binance vs Uniswap) - bps",
      "gridPos": {"x": 0, "y": 13, "w": 16, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "WITH binance_quotes AS (SELECT qr.interval_start, qr.pair_id, qr.close_mid FROM quote_rollups qr JOIN venues v ON v.id = qr.venue_id JOIN pairs p ON p.id = qr.pair_id WHERE v.name = 'binance' AND qr.interval_type = '1s' AND qr.interval_start BETWEEN $__timeFrom() AND $__timeTo() AND qr.close_mid IS NOT NULL AND (${pair} = 0 OR p.id = ${pair})), uniswap_quotes AS (SELECT qr.interval_start, qr.pair_id, qr.close_mid FROM quote_rollups qr JOIN venues v ON v.id = qr.venue_id JOIN pairs p ON p.id = qr.pair_id WHERE v.name = 'uniswap_v3' AND qr.interval_type = '1s' AND qr.interval_start BETWEEN $__timeFrom() AND $__timeTo() AND qr.close_mid IS NOT NULL AND (${pair} = 0 OR p.id = ${pair})) SELECT b.interval_start as time, 10000.0 * (u.close_mid - b.close_mid) / b.close_mid as spread_bps FROM binance_quotes b JOIN uniswap_quotes u ON b.pair_id = u.pair_id AND b.interval_start = u.interval_start ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": 60000,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Spread (bps)",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 20, "color": "orange"},
              {"value": 30, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max", "min"]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Opportunities (15m)",
      "description": "Number of trading opportunities detected in the last 15 minutes",
      "gridPos": {"x": 16, "y": 13, "w": 8, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COUNT(*) as value FROM opportunities WHERE detected_at BETWEEN $__timeFrom() AND $__timeTo()",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "text"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Spread (15m)",
      "description": "Average spread in basis points for opportunities detected in the last 15 minutes",
      "gridPos": {"x": 16, "y": 17, "w": 8, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COALESCE(AVG(spread_bps), 0) as value FROM opportunities WHERE detected_at BETWEEN $__timeFrom() AND $__timeTo()",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix: bps",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 20, "color": "orange"},
              {"value": 30, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Quote Counts by Venue (15m)",
      "gridPos": {"x": 0, "y": 21, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT v.name as metric, COUNT(*) as value FROM quotes_raw qr JOIN venues v ON v.id = qr.venue_id WHERE qr.ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY v.name ORDER BY value DESC",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 10, "color": "yellow"},
              {"value": 100, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Connector Health Status",
      "gridPos": {"x": 12, "y": 21, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT v.name as venue, ch.chain, ch.ws_connected as connected, ch.last_quote_at, EXTRACT(EPOCH FROM (now() - ch.last_quote_at)) as seconds_ago, ch.reconnect_count as reconnects, ch.error_count as errors FROM connector_health ch JOIN venues v ON v.id = ch.venue_id ORDER BY ch.ws_connected DESC, ch.last_quote_at DESC NULLS LAST",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "connected"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {"text": "Online", "color": "green"},
                      "false": {"text": "Offline", "color": "red"}
                    }
                  }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "red"},
                    {"value": 1, "color": "green"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "seconds_ago"},
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 10, "color": "yellow"},
                    {"value": 30, "color": "orange"},
                    {"value": 60, "color": "red"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "errors"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 1, "color": "yellow"},
                    {"value": 5, "color": "orange"},
                    {"value": 10, "color": "red"}
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent Opportunities",
      "gridPos": {"x": 0, "y": 29, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT o.detected_at, p.canonical as pair, o.chain, o.spread_bps, o.direction, o.status, o.anchor_mid as cex_price, o.dex_mid as dex_price, o.skip_reason FROM opportunities o JOIN pairs p ON p.id = o.pair_id WHERE o.detected_at > now() - interval '15 minutes' ORDER BY o.detected_at DESC LIMIT 50",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {"displayName": "detected_at", "desc": true}
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "spread_bps"},
            "properties": [
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 15, "color": "yellow"},
                    {"value": 30, "color": "orange"},
                    {"value": 50, "color": "red"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "status"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "detected": {"text": "Detected", "color": "blue"},
                      "evaluating": {"text": "Evaluating", "color": "yellow"},
                      "skipped": {"text": "Skipped", "color": "gray"},
                      "submitted": {"text": "Submitted", "color": "green"},
                      "filled": {"text": "Filled", "color": "dark-green"},
                      "reverted": {"text": "Reverted", "color": "red"},
