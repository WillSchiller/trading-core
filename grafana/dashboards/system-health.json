            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 200, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Max Latency (1h)",
      "gridPos": {"x": 12, "y": 16, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT MAX(latency_ms) as value FROM quotes_raw WHERE ts > now() - interval '1 hour' AND exchange_ts_ms IS NOT NULL AND latency_ms >= 0",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1000, "color": "yellow"},
              {"value": 3000, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Stale Quotes (1h)",
      "gridPos": {"x": 16, "y": 16, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COUNT(*) as value FROM quotes_raw WHERE ts > now() - interval '1 hour' AND is_stale = true",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 100, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Total Quotes (1h)",
      "gridPos": {"x": 20, "y": 16, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COUNT(*) as value FROM quotes_raw WHERE ts > now() - interval '1 hour'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"value": null, "color": "blue"}]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "table",
      "title": "Connector Health Summary",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 6},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT v.name as venue, COUNT(*) as quotes_1h, ROUND(AVG(latency_ms)) as avg_latency_ms, ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency_ms)) as p95_latency_ms, MAX(latency_ms) as max_latency_ms, SUM(CASE WHEN latency_ms < 0 THEN 1 ELSE 0 END) as future_ts_count, SUM(CASE WHEN is_stale THEN 1 ELSE 0 END) as stale_count, MAX(q.ts) as last_quote_at FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE q.ts > now() - interval '1 hour' GROUP BY v.name ORDER BY v.name",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "avg_latency_ms"}, "properties": [{"id": "unit", "value": "ms"}]},
          {"matcher": {"id": "byName", "options": "p95_latency_ms"}, "properties": [{"id": "unit", "value": "ms"}]},
          {"matcher": {"id": "byName", "options": "max_latency_ms"}, "properties": [{"id": "unit", "value": "ms"}]},
          {"matcher": {"id": "byName", "options": "future_ts_count"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "red"}]}}]},
          {"matcher": {"id": "byName", "options": "stale_count"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 10, "color": "yellow"}, {"value": 100, "color": "red"}]}}]}
        ]
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Time Alignment Skew (CEX vs DEX observed_at)",
      "description": "Difference between when we received the CEX quote vs DEX quote. Large values indicate temporal mismatch in comparisons.",
      "gridPos": {"x": 0, "y": 26, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "WITH cex_quotes AS (SELECT ts, received_ts_ms, pair_id FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.venue_type = 'cex' AND v.name = 'binance' AND q.ts BETWEEN $__timeFrom() AND $__timeTo()), dex_quotes AS (SELECT ts, received_ts_ms, pair_id FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.venue_type = 'dex' AND q.ts BETWEEN $__timeFrom() AND $__timeTo()) SELECT date_trunc('minute', c.ts) as time, 'cex_dex_skew' as metric, ROUND(AVG(ABS(c.received_ts_ms - d.received_ts_ms))) as value FROM cex_quotes c JOIN dex_quotes d ON c.pair_id = d.pair_id AND ABS(EXTRACT(EPOCH FROM (c.ts - d.ts))) < 60 GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": {"mode": "line+area"}
          },
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1500, "color": "yellow"},
              {"value": 3000, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}
      }
    }
  ]
}
