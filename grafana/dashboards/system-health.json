{
  "id": null,
  "uid": "system-health",
  "title": "System Health",
  "tags": ["pca-stat-arb", "ops"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Connector Status",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Connected Venues",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*) FILTER (WHERE ws_connected = true) || '/' || COUNT(*) AS \"Connected\" FROM connector_health",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Hyperliquid WS",
      "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT CASE WHEN ws_connected THEN 'CONNECTED' ELSE 'DISCONNECTED' END AS \"Status\" FROM connector_health ch JOIN venues v ON v.id = ch.venue_id WHERE v.name IN ('binance', 'coinbase') AND ws_connected = true ORDER BY ch.updated_at DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"CONNECTED": {"color": "green", "text": "CONNECTED"}}},
            {"type": "value", "options": {"DISCONNECTED": {"color": "red", "text": "DISCONNECTED"}}}
          ],
          "color": {"mode": "fixed", "fixedColor": "green"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Reconnects",
      "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT SUM(reconnect_count) AS \"Reconnects\" FROM connector_health",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": 0, "color": "green"},
            {"value": 50, "color": "yellow"},
            {"value": 200, "color": "red"}
          ]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Errors",
      "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT SUM(error_count) AS \"Errors\" FROM connector_health",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": 0, "color": "green"},
            {"value": 10, "color": "yellow"},
            {"value": 100, "color": "red"}
          ]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"}
    },

    {
      "id": 101,
      "type": "row",
      "title": "Connector Details",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 10,
      "type": "table",
      "title": "Connector Health Details",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT v.name AS \"Venue\", ch.ws_connected AS \"Connected\", ch.last_quote_at AS \"Last Quote\", ROUND(EXTRACT(EPOCH FROM (now() - ch.last_quote_at))::numeric, 0) AS \"Stale (s)\", ch.reconnect_count AS \"Reconnects\", ch.error_count AS \"Errors\", ch.updated_at AS \"Updated\" FROM connector_health ch JOIN venues v ON v.id = ch.venue_id ORDER BY ch.ws_connected DESC, ch.last_quote_at DESC NULLS LAST",
        "format": "table"
      }],
      "options": {"showHeader": true, "sortBy": [{"displayName": "Stale (s)", "desc": false}]},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Connected"},
            "properties": [
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "mappings", "value": [
                {"type": "value", "options": {"true": {"color": "green", "text": "Yes"}}},
                {"type": "value", "options": {"false": {"color": "red", "text": "No"}}}
              ]}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Stale (s)"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [
                {"value": 0, "color": "green"},
                {"value": 30, "color": "yellow"},
                {"value": 60, "color": "red"}
              ]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Errors"},
            "properties": [
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]}}
            ]
          }
        ]
      }
    },

    {
      "id": 102,
      "type": "row",
      "title": "Market Context Service",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Last Market Context Poll",
      "gridPos": {"x": 0, "y": 15, "w": 8, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (now() - to_timestamp(MAX(\"timestamp\") / 1000)))::numeric, 0) AS \"Seconds Ago\" FROM market_context_snapshots",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": 0, "color": "green"},
            {"value": 300, "color": "yellow"},
            {"value": 600, "color": "red"}
          ]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Assets Tracked",
      "gridPos": {"x": 8, "y": 15, "w": 8, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(DISTINCT asset) AS \"Assets\" FROM market_context_snapshots WHERE to_timestamp(\"timestamp\" / 1000) > now() - interval '1 hour'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": 0, "color": "red"},
            {"value": 50, "color": "yellow"},
            {"value": 80, "color": "green"}
          ]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Snapshots (1h)",
      "gridPos": {"x": 16, "y": 15, "w": 8, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*) AS \"Snapshots\" FROM market_context_snapshots WHERE to_timestamp(\"timestamp\" / 1000) > now() - interval '1 hour'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "blue"}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },

    {
      "id": 103,
      "type": "row",
      "title": "Signal Pipeline",
      "gridPos": {"x": 0, "y": 19, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 30,
      "type": "stat",
      "title": "Last Signal",
      "gridPos": {"x": 0, "y": 20, "w": 8, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (now() - to_timestamp(MAX(\"timestamp\") / 1000)))::numeric, 0) AS \"Seconds Ago\" FROM pca_signals",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": 0, "color": "green"},
            {"value": 300, "color": "yellow"},
            {"value": 600, "color": "red"}
          ]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Unresolved Signals",
      "gridPos": {"x": 8, "y": 20, "w": 8, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*) AS \"Open\" FROM pca_signals WHERE resolved = false",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": 0, "color": "blue"},
            {"value": 10, "color": "yellow"},
            {"value": 50, "color": "red"}
          ]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Signals (1h)",
      "gridPos": {"x": 16, "y": 20, "w": 8, "h": 4},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT COUNT(*) AS \"Signals\" FROM pca_signals WHERE to_timestamp(\"timestamp\" / 1000) > now() - interval '1 hour'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": 0, "color": "red"},
            {"value": 1, "color": "yellow"},
            {"value": 5, "color": "green"}
          ]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },

    {
      "id": 104,
      "type": "row",
      "title": "Signal Rate",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Signals per Hour",
      "gridPos": {"x": 0, "y": 25, "w": 24, "h": 8},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT date_trunc('hour', to_timestamp(\"timestamp\" / 1000)) AS time, direction AS metric, COUNT(*) AS value FROM pca_signals WHERE to_timestamp(\"timestamp\" / 1000) BETWEEN $__timeFrom()::timestamptz AND $__timeTo()::timestamptz GROUP BY 1, 2 ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "lineWidth": 0, "stacking": {"mode": "normal"}},
          "unit": "short",
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "short"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "long"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "random_short"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]}
        ]
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },

    {
      "id": 105,
      "type": "row",
      "title": "Kill Switch History",
      "gridPos": {"x": 0, "y": 33, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 50,
      "type": "table",
      "title": "Recent Kill Switch Events",
      "gridPos": {"x": 0, "y": 34, "w": 24, "h": 6},
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "postgresql"},
        "rawSql": "SELECT created_at AS \"Time\", run_id AS \"Run\", reason AS \"Reason\", ROUND(daily_pnl::numeric, 2) AS \"Daily PnL ($)\", consecutive_losses AS \"Consec Losses\", positions_closed_count AS \"Closed\" FROM perps_kill_switch_events ORDER BY created_at DESC LIMIT 10",
        "format": "table"
      }],
      "options": {"showHeader": true, "sortBy": [{"displayName": "Time", "desc": true}]},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Reason"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-background-solid"}},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "red"}]}}
            ]
          }
        ]
      }
    }
  ]
}