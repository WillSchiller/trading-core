{
  "id": null,
  "uid": "system-health",
  "title": "System Health",
  "tags": ["dislocation-trader", "system"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Clock Drift by Venue (ms)",
      "description": "Latency between exchange timestamp and local received time. Negative = future timestamp (clock issue). High positive = network latency or exchange delay.",
      "gridPos": {"x": 0, "y": 0, "w": 16, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT date_trunc('minute', ts) as time, v.name as metric, ROUND(AVG(latency_ms)) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE q.ts BETWEEN $__timeFrom() AND $__timeTo() AND q.exchange_ts_ms IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 500, "color": "yellow"},
              {"value": 1000, "color": "red"}
            ]
          }
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "binance"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "coinbase"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "bybit"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "min"]}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Binance Avg Latency",
      "description": "Average clock drift from Binance in the last 15 minutes",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(AVG(latency_ms)) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.name = 'binance' AND q.ts > now() - interval '15 minutes' AND q.exchange_ts_ms IS NOT NULL",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 100, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Coinbase Avg Latency",
      "description": "Average clock drift from Coinbase in the last 15 minutes",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(AVG(latency_ms)) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.name = 'coinbase' AND q.ts > now() - interval '15 minutes' AND q.exchange_ts_ms IS NOT NULL",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 100, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Bybit Avg Latency",
      "description": "Average clock drift from Bybit in the last 15 minutes",
      "gridPos": {"x": 16, "y": 4, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(AVG(latency_ms)) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.name = 'bybit' AND q.ts > now() - interval '15 minutes' AND q.exchange_ts_ms IS NOT NULL",
          "format": "table"
