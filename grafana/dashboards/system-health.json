          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 200, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "P95 Latency (Bybit)",
      "gridPos": {"x": 8, "y": 16, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency_ms)) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.name = 'bybit' AND q.ts > now() - interval '1 hour' AND q.exchange_ts_ms IS NOT NULL AND q.latency_ms >= 0",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
