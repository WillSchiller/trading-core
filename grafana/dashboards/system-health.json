          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 100, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Future Timestamps (1h)",
      "description": "Quotes with negative latency (exchange timestamp ahead of local clock). Indicates clock sync issue.",
      "gridPos": {"x": 20, "y": 4, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COUNT(*) as value FROM quotes_raw WHERE ts > now() - interval '1 hour' AND latency_ms < 0",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "yellow"},
              {"value": 100, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "histogram",
      "title": "Latency Distribution by Venue (1h)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT latency_ms, v.name as venue FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE q.ts > now() - interval '1 hour' AND q.exchange_ts_ms IS NOT NULL AND q.latency_ms BETWEEN 0 AND 2000 ORDER BY q.ts DESC LIMIT 5000",
          "format": "table"
        }
      ],
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "right"}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {"tooltip": false, "viz": false, "legend": false}
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "latency_ms"},
            "properties": [
              {"id": "unit", "value": "ms"},
              {"id": "custom.fillOpacity", "value": 80}
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Quote Rate by Venue (per minute)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT date_trunc('minute', ts) as time, v.name as metric, COUNT(*) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE q.ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 0,
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": {"mode": "normal"}
          },
          "decimals": 0
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "binance"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "coinbase"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "bybit"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]},
          {"matcher": {"id": "byName", "options": "uniswap_v3"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "sum"]}
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "P95 Latency (Binance)",
      "gridPos": {"x": 0, "y": 16, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency_ms)) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.name = 'binance' AND q.ts > now() - interval '1 hour' AND q.exchange_ts_ms IS NOT NULL AND q.latency_ms >= 0",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 200, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "P95 Latency (Coinbase)",
      "gridPos": {"x": 4, "y": 16, "w": 4, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency_ms)) as value FROM quotes_raw q JOIN venues v ON v.id = q.venue_id WHERE v.name = 'coinbase' AND q.ts > now() - interval '1 hour' AND q.exchange_ts_ms IS NOT NULL AND q.latency_ms >= 0",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
