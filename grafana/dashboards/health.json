{
  "id": null,
  "uid": "health",
  "title": "System Health",
  "tags": ["dislocation-trader", "health"],
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "venue",
        "type": "query",
        "label": "Venue",
        "datasource": {
          "type": "postgres",
          "uid": "postgresql"
        },
        "definition": "SELECT id as __value, name as __text FROM venues WHERE is_enabled = true ORDER BY name",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": "0",
        "current": {},
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "heatmap",
      "title": "Connector Status Timeline",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ch.updated_at as time, v.name as venue, CASE WHEN ch.ws_connected THEN 1 ELSE 0 END as connected FROM connector_health ch JOIN venues v ON v.id = ch.venue_id WHERE ch.updated_at BETWEEN $__timeFrom() AND $__timeTo() AND (${venue} = 0 OR ch.venue_id = ${venue}) ORDER BY time",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 100
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          },
          "mappings": [
            {"type": "value", "value": "0", "text": "Disconnected"},
            {"type": "value", "value": "1", "text": "Connected"}
          ]
        }
      },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "alignValue": "center",
        "rowHeight": 0.9,
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Quote Freshness (seconds since last quote)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT v.name, EXTRACT(EPOCH FROM (now() - ch.last_quote_at)) as seconds_since_quote FROM connector_health ch JOIN venues v ON v.id = ch.venue_id WHERE (${venue} = 0 OR ch.venue_id = ${venue}) ORDER BY v.name",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "min": 0,
          "max": 120,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 30, "color": "yellow"},
              {"value": 60, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Reconnects",
      "description": "Total number of WebSocket reconnection attempts across all venues",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT SUM(reconnect_count) as value FROM connector_health WHERE (${venue} = 0 OR venue_id = ${venue})",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Errors",
      "description": "Total number of errors across all venues",
      "gridPos": {"x": 18, "y": 8, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT SUM(error_count) as value FROM connector_health WHERE (${venue} = 0 OR venue_id = ${venue})",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 100, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DEX Block Lag",
      "description": "Difference between latest quote block and connector last block - should be near zero",
      "gridPos": {"x": 12, "y": 12, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT (SELECT MAX(block_number) FROM quotes_raw WHERE venue_id IN (SELECT id FROM venues WHERE venue_type = 'dex')) - (SELECT MIN(last_block) FROM connector_health WHERE venue_id IN (SELECT id FROM venues WHERE venue_type = 'dex')) as value",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 5, "color": "yellow"},
              {"value": 10, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Connected Venues",
      "description": "Number of venues with active WebSocket connections",
      "gridPos": {"x": 18, "y": 12, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT COUNT(*) as value FROM connector_health WHERE ws_connected = true AND (${venue} = 0 OR venue_id = ${venue})",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "yellow"},
              {"value": 3, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "RPC Latency (from quote latency_ms)",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT qr.ts as time, v.name, AVG(qr.latency_ms) as avg_latency FROM quotes_raw qr JOIN venues v ON v.id = qr.venue_id WHERE qr.ts BETWEEN $__timeFrom() AND $__timeTo() AND (${venue} = 0 OR qr.venue_id = ${venue}) AND qr.latency_ms IS NOT NULL GROUP BY date_trunc('minute', qr.ts), v.name ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Latency (ms)",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 100, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Quote Rate (quotes/sec by venue)",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT date_trunc('minute', qr.ts) as time, v.name, COUNT(*) / 60.0 as quotes_per_sec FROM quotes_raw qr JOIN venues v ON v.id = qr.venue_id WHERE qr.ts BETWEEN $__timeFrom() AND $__timeTo() AND (${venue} = 0 OR qr.venue_id = ${venue}) GROUP BY date_trunc('minute', qr.ts), v.name ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Quotes/sec",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Connector Health Details",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT v.name as venue, v.venue_type, ch.chain, ch.ws_connected as connected, ch.last_quote_at, EXTRACT(EPOCH FROM (now() - ch.last_quote_at)) as seconds_since_quote, ch.last_block, ch.reconnect_count, ch.error_count, ch.updated_at FROM connector_health ch JOIN venues v ON v.id = ch.venue_id WHERE (${venue} = 0 OR ch.venue_id = ${venue}) ORDER BY ch.ws_connected DESC, ch.last_quote_at DESC NULLS LAST",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {"displayName": "seconds_since_quote", "desc": false}
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "connected"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "red"},
                    {"value": 1, "color": "green"}
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "value": "false", "text": "No"},
                  {"type": "value", "value": "true", "text": "Yes"}
                ]
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "seconds_since_quote"},
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 30, "color": "yellow"},
                    {"value": 60, "color": "red"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "reconnect_count"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 5, "color": "yellow"},
                    {"value": 20, "color": "red"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "error_count"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 10, "color": "yellow"},
                    {"value": 50, "color": "red"}
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Reconnect Events",
      "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ch.updated_at as time, v.name, ch.reconnect_count FROM connector_health ch JOIN venues v ON v.id = ch.venue_id WHERE ch.updated_at BETWEEN $__timeFrom() AND $__timeTo() AND (${venue} = 0 OR ch.venue_id = ${venue}) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 0,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Reconnect Count",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Error Count Over Time",
      "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT ch.updated_at as time, v.name, ch.error_count FROM connector_health ch JOIN venues v ON v.id = ch.venue_id WHERE ch.updated_at BETWEEN $__timeFrom() AND $__timeTo() AND (${venue} = 0 OR ch.venue_id = ${venue}) ORDER BY time",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 0,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Error Count",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Risk State by Chain",
      "gridPos": {"x": 0, "y": 40, "w": 24, "h": 6},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT chain, open_exposure_usd, trades_last_hour, last_trade_at, cooldown_until, is_halted, halt_reason, updated_at FROM risk_state ORDER BY chain",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "is_halted"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 1, "color": "red"}
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "value": "false", "text": "No"},
                  {"type": "value", "value": "true", "text": "Yes"}
                ]
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "open_exposure_usd"},
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 3000, "color": "yellow"},
                    {"value": 5000, "color": "red"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "trades_last_hour"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 15, "color": "yellow"},
                    {"value": 20, "color": "red"}
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Detector Status",
      "gridPos": {"x": 0, "y": 46, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Opportunities by Strategy (24h)",
      "description": "Count of opportunities detected by each strategy in the last 24 hours",
      "gridPos": {"x": 0, "y": 47, "w": 12, "h": 6},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT strategy, COUNT(*) as count FROM opportunities WHERE detected_at BETWEEN $__timeFrom() AND $__timeTo() GROUP BY strategy ORDER BY strategy",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": "/^count$/"
        },
        "text": {},
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "yellow"},
              {"value": 10, "color": "green"}
            ]
          },
          "mappings": []
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "strategy": "Strategy",
              "count": "Count"
            }
          }
        }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "Latest Activity per Strategy",
      "description": "When was the last opportunity detected for each strategy",
      "gridPos": {"x": 12, "y": 47, "w": 12, "h": 6},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "SELECT strategy, MAX(detected_at) as last_detected, COUNT(*) as total, COUNT(*) FILTER (WHERE status = 'submitted') as submitted FROM opportunities WHERE detected_at BETWEEN $__timeFrom() AND $__timeTo() GROUP BY strategy ORDER BY last_detected DESC NULLS LAST",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {"displayName": "last_detected", "desc": true}
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "last_detected"},
            "properties": [
              {
                "id": "unit",
