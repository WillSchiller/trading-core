    {
      "id": 17,
      "type": "table",
      "title": "Current Spread vs Threshold by Pair",
      "description": "Shows current CEX/DEX spreads compared to calibrated thresholds. Helps explain why dislocation detector may not be finding opportunities.",
      "gridPos": {"x": 0, "y": 61, "w": 24, "h": 10},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "postgresql"},
          "rawSql": "WITH latest_quotes AS (SELECT DISTINCT ON (venue_id, pair_id) venue_id, pair_id, mid, ts FROM quotes_raw WHERE ts BETWEEN $__timeFrom() AND $__timeTo() ORDER BY venue_id, pair_id, ts DESC), cex_prices AS (SELECT lq.pair_id, AVG(lq.mid) as cex_mid FROM latest_quotes lq JOIN venues v ON v.id = lq.venue_id WHERE v.venue_type = 'cex' AND v.is_anchor = true GROUP BY lq.pair_id), dex_prices AS (SELECT lq.pair_id, lq.mid as dex_mid, v.chain FROM latest_quotes lq JOIN venues v ON v.id = lq.venue_id WHERE v.venue_type = 'dex' GROUP BY lq.pair_id, lq.mid, v.chain), spread_calc AS (SELECT p.canonical as pair, dp.chain, cp.cex_mid, dp.dex_mid, CASE WHEN cp.cex_mid > 0 THEN ((dp.dex_mid - cp.cex_mid) / cp.cex_mid * 10000) ELSE 0 END as current_spread_bps FROM pairs p JOIN cex_prices cp ON cp.pair_id = p.id JOIN dex_prices dp ON dp.pair_id = p.id WHERE p.is_enabled = true) SELECT sc.pair, sc.chain, sc.current_spread_bps, COALESCE(MIN(pvc.min_spread_bps), 15.0) as min_threshold_bps, sc.current_spread_bps - COALESCE(MIN(pvc.min_spread_bps), 15.0) as bps_below_threshold, sc.cex_mid, sc.dex_mid FROM spread_calc sc LEFT JOIN pair_venue_config pvc ON pvc.pair_id IN (SELECT id FROM pairs WHERE canonical = sc.pair) AND pvc.chain::text = sc.chain GROUP BY sc.pair, sc.chain, sc.current_spread_bps, sc.cex_mid, sc.dex_mid ORDER BY ABS(sc.current_spread_bps) DESC",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {"displayName": "current_spread_bps", "desc": true}
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "current_spread_bps"},
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
